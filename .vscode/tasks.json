{
  "version": "2.0.0",
  "windows": {
    "options": {
      "shell": {
        "executable": "cmd.exe",
        "args": ["/c"]
      }
    }
  },
  "tasks": [
    {
      "label": "CMake: Configure (Debug)",
      "type": "shell",
      "command": "platforms\\windows\\msvc_build.bat configure debug",
      "problemMatcher": ["$msCompile"],
      "group": "build"
    },
    {
      "label": "CMake: Build (Debug)",
      "type": "shell",
      "command": "platforms\\windows\\msvc_build.bat build debug",
      "problemMatcher": ["$msCompile"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "dependsOn": []
    },
    {
      "label": "CMake: Configure (RelWithDebInfo)",
      "type": "shell",
      "command": "platforms\\windows\\msvc_build.bat configure relwithdebinfo",
      "problemMatcher": ["$msCompile"],
      "group": "build"
    },
    {
      "label": "CMake: Build (RelWithDebInfo)",
      "type": "shell",
      "command": "platforms\\windows\\msvc_build.bat build relwithdebinfo",
      "problemMatcher": ["$msCompile"],
      "group": "build"
    }
  ]
}
